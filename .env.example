# Copy to .env and fill in. For LOCAL dev the defaults below work as-is
# (only the API keys and GitHub OAuth app need real values).

# --- LLM (z.ai GLM, Anthropic-compatible gateway) ---
# Use your z.ai key here, NOT an sk-ant-... Anthropic key.
ANTHROPIC_API_KEY=your-zai-key
# Empty => official api.anthropic.com. For z.ai GLM models, set the gateway:
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
LLM_SONNET_MODEL=GLM-4.7-Flash
LLM_HAIKU_MODEL=GLM-4.5-Flash

# --- Embeddings ---
VOYAGE_API_KEY=your-voyage-key

# --- GitHub OAuth app ---
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
# Local dev:
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/auth/github/callback
# Production: https://<your-render-app>.onrender.com/auth/github/callback

# --- Datastores ---
# Local (docker compose). Production: Neon connection string, e.g.
#   postgresql+psycopg://USER:PASS@HOST/db?sslmode=require
DATABASE_URL=postgresql+psycopg://osh:osh@localhost:5432/osh
# Local Redis. Production: Upstash, e.g. rediss://default:PASS@HOST:6379
REDIS_URL=redis://localhost:6379/0

# --- Backend / session ---
# Use a long random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-please
# Local dev:
BACKEND_CORS_ORIGINS=http://localhost:3000
# Production: comma-separated, include your Vercel URL, e.g.
#   https://your-app.vercel.app

# Session cookie. Local (same-site) defaults below. In production the
# frontend and backend are on different domains, so set:
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# --- Frontend ---
# Local dev. Production (Vercel env): https://<your-render-app>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional: email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
